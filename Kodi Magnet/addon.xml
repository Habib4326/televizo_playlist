<addon id="plugin.video.KodiMagnet"
       name="Kodi Magnet"
       version="2.0.8"
       provider-name="Habib">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Smart media browser</summary>
        <description>Next-gen Kodi streaming framework</description>
        <platform>all</platform>
    <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>

</addon>